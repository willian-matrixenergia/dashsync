{
  "buildCommand": "cd ../.. && pnpm --filter @dashsync/shared build && pnpm --filter @dashsync/api build",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
