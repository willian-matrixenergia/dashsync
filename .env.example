# ══════════════════════════════════════════════════════════════
# DashSync — Environment Variables Reference
# Copy to .env and fill in all required values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ─── API Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Authentication (SR-001, SR-002) ─────────────────────────
# WS_SECRET: 32+ random bytes, used to sign WebSocket session tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WS_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32

# DASHSYNC_API_KEY: Static API key for REST endpoints
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DASHSYNC_API_KEY=CHANGE_ME_generate_with_crypto_randomBytes_24

# ALLOWED_ORIGINS: Comma-separated list of permitted CORS origins (SR-003)
# Use the IP/hostname of the meeting room server
ALLOWED_ORIGINS=http://localhost:5173,http://192.168.1.100

# ─── Data & Media paths ───────────────────────────────────────
DATA_DIR=/opt/dashsync/data
MEDIA_DIR=/opt/dashsync/media
WALL_DIST_DIR=/opt/dashsync/wall/dist
TABLET_DIST_DIR=/opt/dashsync/tablet/dist

# ─── AI Integration (SR-008) ─────────────────────────────────
# Never hardcode — always from env or Vault
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ─── ClickHouse (optional — required for historical analytics) ─
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=dashsync_rw
CLICKHOUSE_PASSWORD=CHANGE_ME_strong_password
CLICKHOUSE_DB=dashsync

# ─── Camera streams (H-002: URLs never sent to frontend) ─────
# Pattern: CAMERA_URL_{PROJECT_ID_UPPERCASE}=https://...
# CAMERA_URL_PROJ001=https://stream.provider.com/live/token123
# CAMERA_URL_PROJ002=https://stream.provider.com/live/token456
